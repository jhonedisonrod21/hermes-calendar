<?xml version="1.0" encoding="UTF-8"?>
<!-- Formato JRXML de JasperReports 7 (modelo Jackson: secciones con <element kind="..."/>). -->
<jasperReport name="tenant-statistics" pageWidth="595" pageHeight="842" columnWidth="535"
              leftMargin="30" rightMargin="30" topMargin="30" bottomMargin="30">

    <parameter name="TENANT_NAME" class="java.lang.String"/>
    <parameter name="FROM" class="java.lang.String"/>
    <parameter name="TO" class="java.lang.String"/>
    <parameter name="GENERATED_AT" class="java.lang.String"/>
    <parameter name="TOTAL_APPOINTMENTS" class="java.lang.String"/>
    <parameter name="COMPLETION_RATE" class="java.lang.String"/>
    <parameter name="REVENUE_AMOUNT" class="java.lang.String"/>
    <parameter name="CURRENCY" class="java.lang.String"/>
    <parameter name="LOGO_BASE64" class="java.lang.String"/>

    <field name="label" class="java.lang.String"/>
    <field name="count" class="java.lang.String"/>

    <title height="160">
        <element kind="image" x="485" y="0" width="50" height="50" scaleImage="RetainShape" onErrorType="Blank">
            <expression><![CDATA[new java.io.ByteArrayInputStream(java.util.Base64.getDecoder().decode($P{LOGO_BASE64}))]]></expression>
        </element>
        <element kind="staticText" x="0" y="0" width="400" height="16" forecolor="#E0AA2C" fontSize="11.0" bold="true"><text><![CDATA[HERMES CALENDAR]]></text></element>
        <element kind="staticText" x="0" y="20" width="535" height="28" forecolor="#0D347A" fontSize="19.0" bold="true"><text><![CDATA[ESTADÍSTICAS DEL ESTABLECIMIENTO]]></text></element>
        <element kind="textField" x="0" y="52" width="535" height="16" forecolor="#4B5565" fontSize="10.0" blankWhenNull="true"><expression><![CDATA["Establecimiento: " + $P{TENANT_NAME}]]></expression></element>
        <element kind="textField" x="0" y="70" width="535" height="16" forecolor="#7A8599" fontSize="9.0" blankWhenNull="true"><expression><![CDATA["Periodo: " + $P{FROM} + " a " + $P{TO} + "   |   Generado: " + $P{GENERATED_AT}]]></expression></element>

        <element kind="staticText" x="0" y="98" width="170" height="18" forecolor="#7A8599" fontSize="9.0"><text><![CDATA[Total de citas]]></text></element>
        <element kind="textField" x="0" y="114" width="170" height="26" forecolor="#0D347A" fontSize="18.0" bold="true" blankWhenNull="true"><expression><![CDATA[$P{TOTAL_APPOINTMENTS}]]></expression></element>

        <element kind="staticText" x="185" y="98" width="170" height="18" forecolor="#7A8599" fontSize="9.0"><text><![CDATA[Tasa de finalización]]></text></element>
        <element kind="textField" x="185" y="114" width="170" height="26" forecolor="#0D347A" fontSize="18.0" bold="true" blankWhenNull="true"><expression><![CDATA[$P{COMPLETION_RATE}]]></expression></element>

        <element kind="staticText" x="365" y="98" width="170" height="18" forecolor="#7A8599" fontSize="9.0"><text><![CDATA[Ingresos cobrados]]></text></element>
        <element kind="textField" x="365" y="114" width="170" height="26" forecolor="#1F9D55" fontSize="15.0" bold="true" blankWhenNull="true"><expression><![CDATA[$P{REVENUE_AMOUNT} + " " + $P{CURRENCY}]]></expression></element>
    </title>

    <columnHeader height="24">
        <element kind="staticText" x="0" y="2" width="535" height="18" forecolor="#172033" fontSize="11.0" bold="true" vTextAlign="Middle"><text><![CDATA[Citas por estado]]></text></element>
    </columnHeader>

    <detail>
        <band height="22">
            <element kind="textField" x="0" y="0" width="400" height="22" fontSize="10.0" vTextAlign="Middle" blankWhenNull="true"><expression><![CDATA[$F{label}]]></expression></element>
            <element kind="textField" x="400" y="0" width="135" height="22" forecolor="#0D347A" fontSize="11.0" bold="true" hTextAlign="Right" vTextAlign="Middle" blankWhenNull="true"><expression><![CDATA[$F{count}]]></expression></element>
            <element kind="line" x="0" y="21" width="535" height="1" forecolor="#E3E8F0"/>
        </band>
    </detail>
</jasperReport>
